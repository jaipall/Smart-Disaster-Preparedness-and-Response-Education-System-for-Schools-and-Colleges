# Copy this file to `.env` before running the backend locally.
# The backend loads environment variables using `dotenv.config()`, which by default
# reads from a file named `.env` in the project root.

# Backend port (server also defaults to 5001 if not provided)
PORT=5001

# Frontend URL used for CORS
CLIENT_URL=http://localhost:5173

# JWT signing/verifying secret (required by src/config/env.js)
SECRET_PRIVATE_KEY=replace_me_with_a_long_random_secret

# MongoDB connection string (required by src/lib/db.js)
MONGODB_URL=mongodb://127.0.0.1:27017/smart-disaster-preparedness

# Used to set cookie security attributes
NODE_ENV=development

